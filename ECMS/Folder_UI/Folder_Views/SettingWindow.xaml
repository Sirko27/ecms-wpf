<Window x:Class="ECMS.Folder_UI.Folder_Views.SettingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ECMS.Folder_UI.Folder_Views"
        mc:Ignorable="d"
        Title="Налаштування пристрою" Height="260" Width="320" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Назва пристрою:" Grid.Row="0" FontWeight="Bold"  Margin="0,0,0,4"/>
        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Margin="0,4,0,2"/>
        <TextBlock Text="{Binding ErrorName}" Grid.Row="2" Foreground="Red" FontSize="11" Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>

        <TextBlock Text="Мах. швидкість: " Grid.Row="3" FontWeight="Bold"  Margin="0,8,0,4"/>
        <TextBox Text="{Binding MaxSpeed, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Margin="0,4,0,2"/>
        <TextBlock Text="{Binding ErrorMaxSpeed}" Grid.Row="5" Foreground="Red" FontSize="11" Margin="0,0,0,8" TextTrimming="CharacterEllipsis"/>
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Зберегти" Command="{Binding SaveCommand}" Width="80" Margin="5" IsDefault="True"/>
            <Button Content="Скасувати" Command="{Binding CancelCommand}" Width="80" Margin="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
