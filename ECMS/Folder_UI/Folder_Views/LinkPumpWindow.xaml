<Window x:Class="ECMS.Folder_UI.Folder_Views.LinkPumpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ECMS.Folder_UI.Folder_Views"
        mc:Ignorable="d"
        Title="Link Pump Motor" Height="280" Width="320" WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Оберіть двигун для прив'язки:" FontWeight="Bold" Margin="0,0,0,8"/>

        <ListBox Grid.Row="1" ItemsSource="{Binding Motors}" SelectedItem="{Binding SelectedMotor}" DisplayMemberPath="Name" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Підтвердити" Command="{Binding LinkCommand}" Width="90" Margin="5"/>
            <Button Content="Скасувати" Command="{Binding CancelCommand}" Width="90" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
